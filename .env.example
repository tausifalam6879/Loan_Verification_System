# Backend LLM settings. Do not put these keys in React/frontend env files.
# React calls only POST /api/ai/chat; provider calls happen on the backend.

# Local development with Ollama
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.2:3b
LLM_TIMEOUT_MS=15000

# Public demo/deployment with Gemini
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-1.5-flash
GEMINI_API_KEY=

# Public demo/deployment with OpenAI
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Use when LLM_PROVIDER=openai-compatible, for Odysseus or any local /v1 endpoint
LOCAL_LLM_BASE_URL=http://localhost:7000/v1
LOCAL_LLM_API_KEY=
